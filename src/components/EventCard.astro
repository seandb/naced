---
interface Props {
  title: string;
  date: string;
  endDate?: string;
  location?: string;
  category?: string;
  slug: string;
  registrationUrl?: string;
}

const { title, date, endDate, location, category, slug, registrationUrl } = Astro.props;

const eventDate = new Date(date);
const month = eventDate.toLocaleString('en-US', { month: 'short' }).toUpperCase();
const day = eventDate.getDate();
const year = eventDate.getFullYear();
const time = eventDate.toLocaleString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });

const categoryColors: Record<string, string> = {
  Workshop: 'bg-blue-100 text-blue-800',
  Conference: 'bg-purple-100 text-purple-800',
  Webinar: 'bg-green-100 text-green-800',
  Community: 'bg-orange-100 text-orange-800',
};
const badgeClass = category ? (categoryColors[category] || 'bg-gray-100 text-gray-700') : 'bg-gray-100 text-gray-700';
---

<article class="group flex gap-5 p-5 bg-white rounded-2xl border border-gray-100 hover:border-teal-primary/30 hover:shadow-md transition-all duration-200">
  <!-- Date badge -->
  <div
    class="flex-shrink-0 w-16 h-16 rounded-xl flex flex-col items-center justify-center text-white"
    style="background-color: #0D5C63;"
    aria-label={`Event date: ${month} ${day}, ${year}`}
  >
    <span class="text-xs font-bold tracking-widest opacity-80">{month}</span>
    <span class="font-heading font-bold text-2xl leading-none">{day}</span>
  </div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2 mb-1.5">
      <h3 class="font-heading text-lg font-bold leading-snug group-hover:text-teal-primary transition-colors line-clamp-2" style="color: #1A1A2E;">
        <a href={`/events/${slug}`} class="hover:underline focus:outline-none focus:underline">
          {title}
        </a>
      </h3>
      {category && (
        <span class={`flex-shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full ${badgeClass}`}>
          {category}
        </span>
      )}
    </div>

    <div class="flex flex-wrap gap-3 text-sm text-gray-500">
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {time} · {year}
      </span>
      {location && (
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          {location}
        </span>
      )}
    </div>

    <div class="flex gap-3 mt-3">
      <a
        href={`/events/${slug}`}
        class="text-sm font-semibold transition-colors"
        style="color: #0D5C63;"
      >
        Event details →
      </a>
      {registrationUrl && (
        <a
          href={registrationUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-semibold px-3 py-1 rounded-full text-white transition-opacity hover:opacity-90"
          style="background-color: #D4A853; color: #1A1A2E;"
        >
          Register
        </a>
      )}
    </div>
  </div>
</article>
