---
const quickLinks = [
  { label: 'About NACED', href: '/about' },
  { label: 'Our Programs', href: '/programs' },
  { label: 'Events', href: '/events' },
  { label: 'News', href: '/news' },
  { label: 'Contact', href: '/contact' },
  { label: 'Donate', href: '/donate' },
];

const year = new Date().getFullYear();
---

<footer style="background-color: #1A1A2E;" class="text-white" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-12 border-b border-white/10">

      <!-- Column 1: Logo + Tagline -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4" aria-label="NACED home">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #D4A853;">
            <span class="font-heading font-bold text-lg leading-none" style="color: #1A1A2E;">N</span>
          </div>
          <span class="font-heading font-bold text-xl text-white">NACED</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-6">
          National Association for Creative Economic Development — advancing communities through the power of creativity, culture, and innovation.
        </p>
        <!-- Social links -->
        <div class="flex gap-3" aria-label="Social media links">
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" aria-label="Twitter / X">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" aria-label="LinkedIn">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-widest mb-5" style="color: #D4A853;">Quick Links</h3>
        <ul class="space-y-2.5">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-gray-400 hover:text-white transition-colors inline-flex items-center gap-1.5 group"
              >
                <span class="w-1 h-1 rounded-full bg-gold-accent opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0" style="background-color: #D4A853;"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-widest mb-5" style="color: #D4A853;">Contact</h3>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #D4A853;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@naced.org" class="hover:text-white transition-colors">info@naced.org</a>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #D4A853;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+13125550100" class="hover:text-white transition-colors">(312) 555-0100</a>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #D4A853;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <address class="not-italic leading-relaxed">
              123 Creative Commons Dr<br />
              Chicago, IL 60601
            </address>
          </li>
        </ul>
      </div>

      <!-- Column 4: Newsletter / Mission -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-widest mb-5" style="color: #D4A853;">Stay Connected</h3>
        <p class="text-sm text-gray-400 mb-4 leading-relaxed">
          Get our monthly newsletter with stories of impact, upcoming events, and opportunities to get involved.
        </p>
        <form class="flex flex-col gap-2" aria-label="Newsletter signup">
          <input
            type="email"
            placeholder="your@email.com"
            class="px-4 py-2.5 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-500 text-sm focus:outline-none focus:border-white/40 transition-colors"
            aria-label="Email address"
          />
          <button
            type="submit"
            class="px-4 py-2.5 rounded-lg text-sm font-semibold transition-all hover:opacity-90"
            style="background-color: #D4A853; color: #1A1A2E;"
          >
            Subscribe
          </button>
        </form>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <p>&copy; {year} NACED — National Association for Creative Economic Development. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/privacy" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-gray-300 transition-colors">Terms of Use</a>
        <a href="/accessibility" class="hover:text-gray-300 transition-colors">Accessibility</a>
      </div>
    </div>

  </div>
</footer>
