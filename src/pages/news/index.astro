---
import Layout from '../../layouts/Layout.astro';
import NewsCard from '../../components/NewsCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import { sanityFetch, urlFor } from '../../lib/sanity';

const posts = await sanityFetch<any[]>(`*[_type == "post"] | order(publishedAt desc){
  _id, title, slug, excerpt, category, publishedAt, author, mainImage, featured
}`);

const fallbackPosts = [
  { _id: 'p1', title: 'How Creative Districts Are Revitalizing Rust Belt Cities', excerpt: 'Five years into our partnership with three Midwestern cities, the data is clear: investing in arts infrastructure pays dividends far beyond the cultural sector.', category: 'Report', publishedAt: '2026-03-10T00:00:00Z', author: 'Maria Chen', slug: { current: 'creative-districts-rust-belt' }, featured: true },
  { _id: 'p2', title: 'Meet Jamal: From Food Truck to Brick-and-Mortar', excerpt: 'Through NACED\'s Accelerator program, chef and entrepreneur Jamal Washington built the business acumen to open his first restaurant — and he\'s not stopping there.', category: 'Story', publishedAt: '2026-02-25T00:00:00Z', author: 'Lisa Park', slug: { current: 'meet-jamal-food-truck' }, featured: false },
  { _id: 'p3', title: 'NACED Releases 2025 State of Creative Economies Report', excerpt: 'Our flagship annual report documents the health of creative economies across 48 communities, revealing both encouraging trends and persistent challenges.', category: 'Announcement', publishedAt: '2026-02-01T00:00:00Z', author: 'NACED Staff', slug: { current: 'state-of-creative-economies-2025' }, featured: false },
  { _id: 'p4', title: 'What the 2025 NEA Budget Cuts Mean for Creative Entrepreneurs', excerpt: 'An honest analysis of recent federal arts funding reductions — and what artists and community organizations can do to adapt and advocate.', category: 'News', publishedAt: '2026-01-15T00:00:00Z', author: 'Dr. Sarah Kim', slug: { current: 'nea-budget-cuts-2025' }, featured: false },
  { _id: 'p5', title: 'The Hidden Economy of Craft Fairs: New Data', excerpt: 'A new NACED study reveals that craft and maker markets generate 3x the economic activity previously estimated — and most of it stays local.', category: 'Report', publishedAt: '2025-12-10T00:00:00Z', author: 'Maria Chen', slug: { current: 'craft-fair-economy-data' }, featured: false },
  { _id: 'p6', title: 'NACED Welcomes Five New Board Members', excerpt: 'We\'re thrilled to announce the addition of five outstanding leaders to the NACED board, bringing expertise in law, finance, urban planning, and the arts.', category: 'Announcement', publishedAt: '2025-11-20T00:00:00Z', author: 'NACED Staff', slug: { current: 'new-board-members-2025' }, featured: false },
];

const displayPosts = posts && posts.length > 0 ? posts : fallbackPosts;
const featured = displayPosts.find((p: any) => p.featured);
const rest = displayPosts.filter((p: any) => !p.featured || p._id !== featured?._id);

const categories = ['All', 'News', 'Story', 'Report', 'Announcement', 'Press Release'];
---

<Layout title="News & Stories — NACED" description="Read the latest news, impact stories, research reports, and announcements from NACED.">
  <!-- Header -->
  <div class="py-24 text-white" style="background: linear-gradient(135deg, #0D5C63 0%, #094A50 100%);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 mb-5" aria-hidden="true">
        <div class="w-8 h-px" style="background-color: #D4A853;"></div>
        <span class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: #D4A853;">From the Field</span>
        <div class="w-8 h-px" style="background-color: #D4A853;"></div>
      </div>
      <h1 class="font-heading font-bold text-white mb-5" style="font-size: clamp(2.5rem, 5vw, 4rem);">News & Stories</h1>
      <p class="text-xl text-white/80 leading-relaxed max-w-2xl mx-auto">
        Stories of impact, research findings, and news from the creative economy communities we serve.
      </p>
    </div>
  </div>

  <div class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Featured post -->
      {featured && (
        <div class="mb-16">
          <div class="inline-flex items-center gap-2 mb-6">
            <div class="w-8 h-px" style="background-color: #D4A853;" aria-hidden="true"></div>
            <span class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: #D4A853;">Featured Story</span>
          </div>
          <article class="grid lg:grid-cols-2 gap-0 rounded-3xl overflow-hidden shadow-xl border border-gray-100">
            <div class="aspect-video lg:aspect-auto overflow-hidden" style="background: linear-gradient(135deg, #0D5C63, #1A1A2E);">
              {featured.mainImage ? (
                <img
                  src={urlFor(featured.mainImage).width(800).height(500).url()}
                  alt={featured.title}
                  class="w-full h-full object-cover"
                  loading="eager"
                />
              ) : (
                <div class="w-full h-full min-h-64 flex items-center justify-center">
                  <svg class="w-16 h-16 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                </div>
              )}
            </div>
            <div class="p-8 lg:p-10 flex flex-col justify-center" style="background-color: #F7F9F8;">
              <div class="flex gap-3 mb-4">
                {featured.category && (
                  <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color: #E8F5F6; color: #0D5C63;">{featured.category}</span>
                )}
                <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color: #D4A853; color: #1A1A2E;">Featured</span>
              </div>
              <h2 class="font-heading text-3xl font-bold mb-4 leading-snug" style="color: #1A1A2E;">
                <a href={`/news/${featured.slug?.current || featured.slug}`} class="hover:underline">{featured.title}</a>
              </h2>
              {featured.excerpt && <p class="text-gray-600 leading-relaxed mb-6">{featured.excerpt}</p>}
              <div class="flex items-center justify-between mt-auto">
                {featured.author && <span class="text-sm text-gray-400">By {featured.author}</span>}
                <a
                  href={`/news/${featured.slug?.current || featured.slug}`}
                  class="inline-flex items-center gap-1.5 font-semibold text-sm transition-all hover:gap-2.5"
                  style="color: #0D5C63;"
                >
                  Read more →
                </a>
              </div>
            </div>
          </article>
        </div>
      )}

      <!-- Post grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {rest.map((post: any) => (
          <NewsCard
            title={post.title}
            excerpt={post.excerpt}
            category={post.category}
            publishedAt={post.publishedAt}
            author={post.author}
            slug={post.slug?.current || post.slug}
            imageUrl={post.mainImage ? urlFor(post.mainImage).width(600).height(340).url() : undefined}
          />
        ))}
      </div>
    </div>
  </div>

  <CTABanner
    heading="Stay in the Loop"
    subtext="Subscribe to our newsletter and never miss a story, event, or opportunity from NACED."
    primaryLabel="Get Our Newsletter"
    primaryHref="/contact#newsletter"
    secondaryLabel="Follow on Social"
    secondaryHref="/contact"
  />
</Layout>
