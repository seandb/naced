---
import Layout from '../layouts/Layout.astro';
import { sanityFetch } from '../lib/sanity';

const settings = await sanityFetch<any>(`*[_type == "siteSettings"][0]{ contactInfo }`);
const contactData = await sanityFetch<any>(`*[_type == "contactPage"][0]{ pageHeader }`);

const email = settings?.contactInfo?.email || 'info@naced.org';
const phone = settings?.contactInfo?.phone || '(312) 555-0192';
const address = settings?.contactInfo?.address || '150 N. Michigan Ave, Suite 2800\nChicago, IL 60601';
const hours = settings?.contactInfo?.hours || 'Mon – Fri, 9am – 5pm CT';
---

<Layout
  title="Contact — NACED"
  description="Get in touch with NACED. We'd love to hear from you — whether you're an artist, community leader, funder, or policymaker."
>
  <!-- Header -->
  <div class="py-24 text-white" style="background: linear-gradient(135deg, #0D5C63 0%, #094A50 100%);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 mb-5" aria-hidden="true">
        <div class="w-8 h-px" style="background-color: #D4A853;"></div>
        <span class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: #D4A853;">{contactData?.pageHeader?.eyebrow || 'Get in Touch'}</span>
        <div class="w-8 h-px" style="background-color: #D4A853;"></div>
      </div>
      <h1 class="font-heading font-bold text-white mb-5" style="font-size: clamp(2.5rem, 5vw, 4rem);">{contactData?.pageHeader?.heading || 'Contact NACED'}</h1>
      <p class="text-xl text-white/80 leading-relaxed max-w-2xl mx-auto">
        {contactData?.pageHeader?.subheading || 'Whether you\'re a creative entrepreneur, community leader, potential partner, or supporter — we want to hear from you.'}
      </p>
    </div>
  </div>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-16">

        <!-- Contact info -->
        <aside class="lg:col-span-2">
          <h2 class="font-heading text-2xl font-bold mb-8" style="color: #1A1A2E;">Our Information</h2>

          <div class="space-y-6 mb-10">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #E8F5F6;">
                <svg class="w-5 h-5" style="color: #0D5C63;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Email</div>
                <a href={`mailto:${email}`} class="font-medium hover:underline" style="color: #0D5C63;">{email}</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #E8F5F6;">
                <svg class="w-5 h-5" style="color: #0D5C63;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Phone</div>
                <a href={`tel:${phone.replace(/\D/g,'')}`} class="font-medium hover:underline" style="color: #0D5C63;">{phone}</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #E8F5F6;">
                <svg class="w-5 h-5" style="color: #0D5C63;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Address</div>
                <address class="not-italic font-medium text-gray-700 leading-relaxed" set:html={address.replace(/\n/g, '<br />')} />
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #E8F5F6;">
                <svg class="w-5 h-5" style="color: #0D5C63;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Hours</div>
                <p class="font-medium text-gray-700">{hours}</p>
              </div>
            </div>
          </div>

          <!-- Newsletter signup anchor -->
          <div id="newsletter" class="rounded-2xl p-6" style="background-color: #F7F9F8;">
            <h3 class="font-heading text-lg font-bold mb-3" style="color: #1A1A2E;">Newsletter</h3>
            <p class="text-sm text-gray-600 mb-4">Monthly updates on NACED programs, research, events, and impact stories.</p>
            <form aria-label="Newsletter signup" class="flex flex-col gap-3">
              <input
                type="text"
                name="name"
                placeholder="Your name"
                class="px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-teal-primary transition-colors"
                style="--focus-color: #0D5C63;"
                aria-label="Your name"
              />
              <input
                type="email"
                name="email"
                placeholder="Your email address"
                required
                class="px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-teal-primary transition-colors"
                aria-label="Email address"
              />
              <button
                type="submit"
                class="px-4 py-3 rounded-xl font-semibold text-sm transition-all hover:opacity-90"
                style="background-color: #D4A853; color: #1A1A2E;"
              >
                Subscribe to Newsletter
              </button>
            </form>
          </div>
        </aside>

        <!-- Contact form -->
        <div class="lg:col-span-3">
          <h2 class="font-heading text-2xl font-bold mb-8" style="color: #1A1A2E;">Send a Message</h2>

          <form
            name="contact"
            method="POST"
            data-netlify="true"
            class="space-y-5"
            aria-label="Contact form"
          >
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="contact-name" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  Full Name <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none transition-colors"
                  placeholder="Jane Smith"
                />
              </div>
              <div>
                <label for="contact-email" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  Email Address <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none transition-colors"
                  placeholder="jane@example.com"
                />
              </div>
            </div>

            <div>
              <label for="contact-org" class="block text-sm font-semibold text-gray-700 mb-1.5">Organization</label>
              <input
                type="text"
                id="contact-org"
                name="organization"
                autocomplete="organization"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none transition-colors"
                placeholder="Organization name (optional)"
              />
            </div>

            <div>
              <label for="contact-subject" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Subject <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <select
                id="contact-subject"
                name="subject"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none transition-colors bg-white"
              >
                <option value="">Select a topic…</option>
                <option value="programs">Program Inquiry</option>
                <option value="partnership">Partnership / Collaboration</option>
                <option value="funding">Funding / Grants</option>
                <option value="media">Media / Press</option>
                <option value="speaking">Speaking Request</option>
                <option value="research">Research &amp; Data</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="contact-message" class="block text-sm font-semibold text-gray-700 mb-1.5">
                Message <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="6"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none transition-colors resize-y"
                placeholder="Tell us how we can help…"
              ></textarea>
            </div>

            <!-- Honeypot for spam -->
            <div class="hidden" aria-hidden="true">
              <input type="text" name="bot-field" tabindex="-1" autocomplete="off" />
            </div>

            <button
              type="submit"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-semibold text-base transition-all hover:opacity-90 hover:shadow-lg"
              style="background-color: #0D5C63; color: white;"
            >
              Send Message
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </button>

            <p class="text-xs text-gray-400 mt-2">
              We typically respond within 2 business days.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
